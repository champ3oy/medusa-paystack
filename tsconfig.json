{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": ".medusa/server",
    "rootDir": ".",
    "types": ["node", "jest"]
  },
  "include": ["src"],
  "exclude": ["node_modules", ".medusa", "dist", "**/*.test.ts"]
}
